-- Fallback UI if Rayfield fails
local function createFallbackUI()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Parent = game.Players.LocalPlayer.PlayerGui
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 300, 0, 200)
    Frame.Position = UDim2.new(0.5, -150, 0.5, -100)
    Frame.BackgroundColor3 = Color3.new(0, 0, 0)
    Frame.BackgroundTransparency = 0.5
    Frame.Parent = ScreenGui
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.Text = "Niv HUB: Rayfield UI failed."
    TextLabel.TextColor3 = Color3.new(1, 1, 1)
    TextLabel.BackgroundTransparency = 1
    TextLabel.TextScaled = true
    TextLabel.Parent = Frame
    return {
        CreateTab = function(self) return { CreateSection = function(self) return {} end } end,
        CreateSection = function(self) return {} end,
        CreateToggle = function(self, args) end,
        CreateSlider = function(self, args) end,
        CreateColorPicker = function(self, args) end,
        CreateParagraph = function(self, args) end,
        CreateDropdown = function(self, args) return { Refresh = function(self, list, bool) end, Set = function(self, val) end } end,
        CreateButton = function(self, args) end,
        Notify = function(self, args) end
    }
end

